{
  "name": "local-telegram-ai-assistant",
  "productName": "SENA",
  "version": "1.0.0",
  "description": "SENA (Smart Engine for Notes & Action) AI Assistant — Telegram, Ollama/llama-server, PostgreSQL, Puppeteer",
  "type": "module",
  "main": "src/gui-main.js",
  "scripts": {
    "postinstall": "node scripts/rebuild-native.js",
    "prestart": "node scripts/rebuild-native.js",
    "start": "node src/index.js",
    "gui": "node src/gui-main.js",
    "gui:web": "node src/gui-main.js",
    "web:dev": "node web/server.mjs",
    "worker": "node src/index.js",
    "dev": "node --watch src/index.js",
    "build": "node --check src/index.js && node --check src/gui-main.js && node --check src/web/startServer.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src scripts",
    "lint:fix": "eslint src scripts --fix",
    "format": "prettier --write \"src/**/*.js\" \"scripts/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"scripts/**/*.js\""
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "node-telegram-bot-api": "^0.66.0",
    "pg": "^8.13.1",
    "puppeteer": "^23.6.0",
    "winston": "^3.15.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.4.0",
    "vitest": "^3.0.0"
  }
}

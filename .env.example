# Telegram — create a bot via @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Optional legacy: comma-separated user IDs that skip the GUI approval queue
# ALLOWED_USER_IDS=123456789,987654321

# LLM backend: ollama | llama-server | openai | gemini (app default when unset: llama-server)
# LLM_PROVIDER=ollama
# LLM_PROVIDER=llama-server
# LLM_PROVIDER=openai
# LLM_PROVIDER=gemini
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...   (or GOOGLE_API_KEY for Gemini)
# LLAMA_SERVER_URL=http://127.0.0.1:8080
# llama.cpp server mode: local (embedded binary) or remote (online URL only)
# LLAMA_SERVER_MODE=local
# LLAMA_SERVER_MODE=remote
# Optional Bearer token when using a hosted llama.cpp server
# LLAMA_SERVER_API_KEY=
# Auto-spawn llama-server.exe from engine/ when the bot starts (same as GUI checkbox)
# AUTO_START_LLAMA_SERVER=1

# Ollama (default: http://127.0.0.1:11434)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
# Unified model name (optional; overrides OLLAMA_MODEL when set in settings.json)
# LLM_MODEL=llama3.2

# Optional: relative folder for llama-server.exe (default: engine)
# ENGINE_DIR=engine

# PostgreSQL — required. Full URL with user and password (SCRAM auth needs both).
# Copy to .env and set your real credentials (not committed).
DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/sena

# Web admin (email login) — created on first DB connect if no admin exists
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=passw0rd14

# Session cookie: set SESSION_SECURE=1 behind HTTPS (auto on NODE_ENV=production)
# SESSION_SECURE=1

# Telegram Login widget: max age of auth_date in seconds (default 3600, max 86400)
# TELEGRAM_LOGIN_MAX_AGE_SEC=3600

# Personal Telegram @username for "Contact SENA Admin" on the login page (opens t.me/…)
# SENA_ADMIN_TELEGRAM=https://t.me/Sena_Ai_assist2_bot

# Google Sign-In for web user login (/login). Create OAuth credentials at:
# https://console.cloud.google.com/apis/credentials (Web application)
# Authorized redirect URI: http://localhost:3847/api/auth/google/callback (match your GUI_PORT)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional fixed redirect (otherwise derived from request Host)
# GOOGLE_REDIRECT_URI=http://localhost:3847/api/auth/google/callback

# Logging: error | warn | info | debug
LOG_LEVEL=info

# Local control panel (npm run gui). Set OPEN_BROWSER=0 to skip opening a browser window.
GUI_PORT=3000
# OPEN_BROWSER=0

# Browser tool (DuckDuckGo web search). Off by default; replies use only the local model.
# WEB_SEARCH=1
BROWSER_TIMEOUT_MS=10000
MAX_BROWSE_PAGES=2
